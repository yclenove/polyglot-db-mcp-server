{
  "name": "@yclenove/polyglot-db-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "polyglot-db-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_en.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "LICENSE",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-name-pattern=. test/registry.test.mjs test/sql-guards.test.mjs test/redis-guards.test.mjs"
  },
  "keywords": [
    "mcp",
    "database",
    "mysql",
    "postgresql",
    "sqlserver",
    "oracle",
    "mongodb",
    "redis",
    "model-context-protocol"
  ],
  "author": "yclenove",
  "license": "MIT",
  "description": "Multi-engine database MCP server (MySQL, PostgreSQL, SQL Server, Oracle, MongoDB, Redis)",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "mongodb": "^6.12.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.21.0",
    "pg": "^8.13.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "oracledb": "^6.7.0"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  }
}
